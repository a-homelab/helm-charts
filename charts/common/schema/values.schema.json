    },
    "appResources": {
      "$ref": "#/definitions/appResources"
    },
    "rawResources": {
      "type": "object",
      "description": "Raw manifests rendered verbatim (map-keyed for overlay identity, unlike the extraObjects array convention). Each entry is a full manifest as a MAP or a literal YAML STRING (both tpl-rendered). Managed touches only: standard labels merged under the manifest's own, namespace defaulted, metadata.name defaulted to <fullname>-<key>. No refs/back-refs \u2014 if something needs referencing, give it a typed appResources home.",
